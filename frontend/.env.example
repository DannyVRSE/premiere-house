# Base URL of the Laravel API, including the /api path and no trailing slash.
#
# Local development:
#   NEXT_PUBLIC_API_BASE=http://localhost:8000/api
#
# Production (Vercel env var): point at the deployed Render backend, e.g.
#   NEXT_PUBLIC_API_BASE=https://premiere-house-api.onrender.com/api
NEXT_PUBLIC_API_BASE=http://localhost:8000/api
